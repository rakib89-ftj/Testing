rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['userId', 'email', 'createdAt']) &&
               data.keys().size() >= 3 &&
               data.userId == request.auth.uid &&
               data.email is string &&
               data.createdAt is timestamp;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email', 'displayName']);

      // Journal Entries
      match /entries/{entryId} {
        function isValidEntry(data) {
          return data.keys().hasAll(['id', 'content', 'timestamp', 'userId']) &&
                 data.userId == request.auth.uid &&
                 data.id == entryId &&
                 data.content is string && data.content.size() <= 10000 &&
                 data.timestamp is timestamp &&
                 (data.get('feedback', true) is bool); // Optional feedback must be bool
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidEntry(request.resource.data) && isValidId(entryId);
        allow update: if isOwner(userId) && isValidEntry(request.resource.data) &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content', 'analysis', 'timestamp', 'feedback']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
